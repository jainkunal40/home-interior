# ─── Database (Neon PostgreSQL) ───────────────────────────────
# Get yours at https://neon.tech (free tier)
DATABASE_URL="postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/sitebooks?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="https://your-app.vercel.app"

# ─── Vercel Blob (File uploads) ──────────────────────────────
# Auto-set when you add Blob storage in Vercel dashboard
BLOB_READ_WRITE_TOKEN=""

# ─── WhatsApp Cloud API (Notifications) ─────────────────────
# Get from Meta Business Settings → WhatsApp → API Setup
# Free for 1000 conversations/month
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─── Telegram Bot (Notifications) ───────────────────────────
# Create a bot via @BotFather on Telegram (completely free, no limits)
TELEGRAM_BOT_TOKEN=""
# Bot username without @ (e.g. ExploreInteriorsBot) — used for deep link generation
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
